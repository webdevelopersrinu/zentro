# Copy this file to .env and fill in real values

# Which port THIS server runs on. On 2 EC2s you can keep 4000 on both.
PORT=4000

# development | production  (production => secure HTTPS-only session cookie)
NODE_ENV=development

# MongoDB connection (single EC2 with Mongo, or Atlas URL)
MONGO_URI=mongodb://localhost:27017/chatapp

# Valkey connection (single EC2 with Valkey, or ElastiCache endpoint)
VALKEY_URL=redis://localhost:6379

# Secret used to sign JWT login tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Secret for the short-lived OAuth handshake session
SESSION_SECRET=change_this_to_another_long_random_secret

# Where the frontend runs. MUST be an exact origin, never "*": the refresh
# cookie is sent with credentials, and browsers reject a wildcard CORS origin
# on credentialed requests. It is also the allowlist for the CSRF guard.
CLIENT_ORIGIN=http://localhost:5173

# ── ThunderID social login ────────────────────────────────────────────────
# PUBLIC base URL of THIS backend. OAuth callback URLs are built from it.
#   local:  http://localhost:4000
#   prod:   https://zentro.srinudesetti.in
SERVER_URL=http://localhost:4000

# PUBLIC base URL of the FRONTEND. Users are redirected here after login.
#   local:  http://localhost:5173
#   prod:   https://zentro.srinudesetti.in
CLIENT_URL=http://localhost:5173

# Google OAuth — from https://console.cloud.google.com (APIs & Services > Credentials)
# Authorized redirect URI to register:  <SERVER_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — from https://github.com/settings/developers (New OAuth App)
# Authorization callback URL to register:  <SERVER_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── SMTP — used only for the email one-time-code login ────────────────────
# Brevo: SMTP & API -> SMTP. The sender MUST be a verified sender in Brevo,
# or the relay will refuse it.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=
SMTP_KEY=
SENDER_EMAIL=
