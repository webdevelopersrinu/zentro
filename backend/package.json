{
  "name": "chat-backend",
  "version": "1.0.0",
  "description": "Real-time chat backend (Express + Socket.IO + Valkey adapter + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "smoke": "node test/smoke.test.js",
    "test:create": "node test/create.test.js",
    "test:update": "node test/update.test.js",
    "test:delete": "node test/delete.test.js",
    "test:crud": "npm run test:create && npm run test:update && npm run test:delete",
    "seed": "node test/seed.js",
    "seed:clean": "node test/seed.js --clean"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "iovalkey": "^0.3.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.5",
    "socket.io-valkey-adapter": "^0.1.1"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
